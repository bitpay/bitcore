{
  "name": "@bitpay-labs/bitcore-hardware",
  "version": "1.0.0",
  "description": "\"Interface with multiple hardware wallets using one library\"",
  "main": "./build/src/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitpay/bitcore.git#master"
  },
  "scripts": {
    "compile": "npm run clean && npm run build",
    "build": "tsc",
    "clean": "rm -rf build",
    "test": "npm run compile && mocha build/test",
    "burner:get-public-key": "npm run compile && node build/examples/burner/getPublicKey.js",
    "burner:sign": "npm run compile && node build/examples/burner/sign.js"
  },
  "keywords": [
    "bitcore",
    "nfc",
    "blockchain"
  ],
  "author": "Micah Maphet",
  "license": "MIT",
  "dependencies": {
    "@arx-research/libhalo": "^1.19.0",
    "nfc-pcsc": "^0.8.1"
  },
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "chai": "6.2.2",
    "mocha": "11.7.6",
    "typescript": "7.0.2"
  }
}
