{
  "name": "@bitpay-labs/bitcore-cli",
  "description": "A Bitcore CLI Wallet",
  "author": "BitPay, Inc",
  "version": "11.10.3",
  "licence": "MIT",
  "private": true,
  "keywords": [
    "bitcoin",
    "multisig",
    "thresholdsig",
    "tss",
    "wallet"
  ],
  "engines": {
    "node": "^22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bitpay/bitcore/tree/master/packages/bitcore-cli"
  },
  "bugs": {
    "url": "https://github.com/bitpay/bitcore/issues"
  },
  "contributors": [
    {
      "name": "Kenny Joseph",
      "email": "kjoseph@bitpay.com"
    }
  ],
  "bin": {
    "bitcore-cli": "./bin/bitcore-cli"
  },
  "scripts": {
    "test": "npm run compile && node copyTestWallets && nyc mocha 'build/test/**/*.js'",
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.prod.json",
    "postbuild": "node createBin -v",
    "postbuild:prod": "npm run postbuild",
    "clean": "rm -rf ./build",
    "compile": "npm run clean && npm run build",
    "lint": "eslint .",
    "fix:errors": "eslint --fix --quiet .",
    "fix:all": "eslint --fix .",
    "fix": "npm run fix:errors"
  },
  "dependencies": {
    "@bitpay-labs/bitcore-mnemonic": "^11.10.3",
    "@bitpay-labs/bitcore-wallet-client": "^11.10.3",
    "@bitpay-labs/crypto-wallet-core": "^11.10.3",
    "@clack/prompts": "1.5.1",
    "commander": "14.0.0",
    "external-editor": "3.1.0"
  },
  "devDependencies": {
    "@bitpay-labs/bitcore-wallet-service": "^11.10.3",
    "@types/chai": "5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "chai": "^5.2.1",
    "mongodb": "^3.5.9",
    "sinon": "^21.0.0",
    "source-map-support": "0.5.16",
    "supertest": "^7.2.2",
    "typescript": "^5.8.3"
  },
  "gitHead": "d1c7f8b0c3a2e4f5b6c7d8e9f0a1b2c3d4e5f6g7"
}
