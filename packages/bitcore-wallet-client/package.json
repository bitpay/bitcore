  },
  "bugs": {
    "url": "https://github.com/bitpay/bitcore/issues"
  },
  "dependencies": {
    "@bitpay-labs/bitcore-mnemonic": "^11.6.6",
    "@bitpay-labs/bitcore-tss": "^11.6.6",
    "@bitpay-labs/crypto-wallet-core": "^11.6.6",
    "async": "0.9.2",
    "bip38": "1.4.0",
    "json-stable-stringify": "1.0.1",
    "preconditions": "2.2.3",
    "sjcl": "1.0.8",
    "superagent": "5.2.2",
    "typescript": "5.7.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@bitpay-labs/bitcore-wallet-service": "^11.6.6",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^5.2.0",
    "@types/node": "22.14.1",
    "browserify": "^13.1.0",
    "chai": "^5.2.0",
    "kbpgp": "^2.1.4",
    "mocha": "^5.2.0",
    "mongodb": "^3.5.9",
    "nyc": "^17.1.0",
    "request-promise": "^4.2.4",
    "sinon": "^7.1.1",
    "supertest": "*",
    "tsx": "^4.21.0"
  },
  "scripts": {
    "coverage": "npm run compile && nyc mocha 'ts_build/test/**/*.test.js'",
    "test": "tsc --noEmit && mocha -r tsx 'test/**/*.test.ts'",
    "test:ci": "npm run test",
    "docs": "TODO ./node_modules/.bin/tsdoc src/lib/* src/lib/common src/lib/errors -o docs && cat README.header.md  docs/*.md LICENSE > README.md",
    "compile": "npm run clean && tsc",
    "build": "tsc && npm run lint",
    "clean": "rm -rf ./ts_build",
    "lint": "eslint .",
    "fix:errors": "eslint --fix --quiet .",
    "fix:all": "eslint --fix .",
    "fix": "npm run fix:errors",
    "pub": "npm run build && npm publish",
    "precommit": "npm run lint"
  },
  "nyc": {
    "include": [
      "ts_build/src",
      "src"
    ],
    "reporter": [
      "html",
      "text-summary"
    ],
    "check-coverage": true,
    "lines": 60,
    "functions": 60,
    "branches": 60,
    "statements": 60
  },
  "gitHead": "a1890ef287c9e5d0e966fb445d15bc59a9393761"
