{
  "version": "8.25.8",
  "scripts": {
    "build": "docker build -t bitcore-node . ",
    "build:docker": "lerna run build:docker --concurrency 1 --stream",
    "watch": "lerna run watch --parallel",
    "postinstall": "npm run bootstrap && npm run compile",
    "bootstrap": "lerna bootstrap",
    "insight:build": "cd ./packages/insight && npm i && npm run build",
    "node": "cd packages/bitcore-node && npm start",
    "bws": "cd packages/bitcore-wallet-service && npm start",
    "compile": "lerna run compile",
    "lint": "eslint .",
    "fix:errors": "eslint --fix --quiet .",
    "fix:all": "eslint --fix .",
    "fix": "npm run fix:errors",
    "precommit": "lerna run --concurrency 1 --stream precommit --since master",
    "test:bitcore-cli": "cd ./packages/bitcore-cli && npm run test",
    "coverage:bitcore-cli": "cd ./packages/bitcore-cli && npm run coverage",
    "test:bitcore-client": "cd ./packages/bitcore-client && npm run test",
    "coverage:bitcore-client": "cd ./packages/bitcore-client && npm run coverage",
    "test:bitcore-lib": "cd ./packages/bitcore-lib && npm run test",
    "coverage:bitcore-lib": "cd ./packages/bitcore-lib && npm run coverage",
    "test:bitcore-lib-cash": "cd ./packages/bitcore-lib-cash && npm run test",
    "coverage:bitcore-lib-cash": "cd ./packages/bitcore-lib-cash && npm run coverage",
    "test:bitcore-lib-doge": "cd ./packages/bitcore-lib-doge && npm run test",
    "coverage:bitcore-lib-doge": "cd ./packages/bitcore-lib-doge && npm run coverage",
    "test:bitcore-lib-ltc": "cd ./packages/bitcore-lib-ltc && npm run test",
    "coverage:bitcore-lib-ltc": "cd ./packages/bitcore-lib-ltc && npm run coverage",
    "test:bitcore-logging": "cd ./packages/bitcore-logging && npm run test",
    "coverage:bitcore-logging": "cd ./packages/bitcore-logging && npm run coverage",
    "test:bitcore-mnemonic": "cd ./packages/bitcore-mnemonic && npm run test",
    "coverage:bitcore-mnemonic": "cd ./packages/bitcore-mnemonic && npm run coverage",
    "test:bitcore-node": "cd ./packages/bitcore-node && npm run test",
    "coverage:bitcore-node": "cd ./packages/bitcore-node && npm run coverage",
    "test:bitcore-p2p": "cd ./packages/bitcore-p2p && npm run test",
    "coverage:bitcore-p2p": "cd ./packages/bitcore-p2p && npm run coverage",
    "test:bitcore-p2p-cash": "cd ./packages/bitcore-p2p-cash && npm run test",
    "coverage:bitcore-p2p-cash": "cd ./packages/bitcore-p2p-cash && npm run coverage",
    "test:bitcore-p2p-doge": "cd ./packages/bitcore-p2p-doge && npm run test",
    "coverage:bitcore-p2p-doge": "cd ./packages/bitcore-p2p-doge && npm run coverage",
    "test:bitcore-tss": "cd ./packages/bitcore-tss && npm run test",
    "coverage:bitcore-tss": "cd ./packages/bitcore-tss && npm run coverage",
    "test:bitcore-wallet-service": "cd ./packages/bitcore-wallet-service && npm run test",
    "coverage:bitcore-wallet-service": "cd ./packages/bitcore-wallet-service && npm run coverage",
    "test:bitcore-wallet-client": "cd ./packages/bitcore-wallet-client && npm run test",
    "coverage:bitcore-wallet-client": "cd ./packages/bitcore-wallet-client && npm run coverage",
    "test:crypto-rpc": "cd ./packages/crypto-rpc && npm run test",
    "coverage:crypto-rpc": "cd ./packages/crypto-rpc && npm run coverage",
    "test:crypto-wallet-core": "cd ./packages/crypto-wallet-core && npm run test",
    "coverage:crypto-wallet-core": "cd ./packages/crypto-wallet-core && npm run coverage"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/node": "22.13.1",
    "cz-customizable": "^5.2.0",
    "eslint": "^9.37.0",
    "eslint-plugin-import": "2.32.0",
    "globals": "^16.4.0",
    "husky": "^2.4.0",
    "lint-staged": "^9.5.0",
    "ts-node": "^8.0.3",
    "typedoc": "^0.15.0",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "lerna": "^5.6.2",
    "typescript": "5.7.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  }
}
